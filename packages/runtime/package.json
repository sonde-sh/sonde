{
  "name": "@sonde-sh/runtime",
  "version": "0.2.0",
  "description": "Deterministic command runtime used for Sonde manifest execution checks.",
  "type": "module",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sonde-sh/sonde.git"
  },
  "homepage": "https://github.com/sonde-sh/sonde#readme",
  "bugs": {
    "url": "https://github.com/sonde-sh/sonde/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/*.js",
    "dist/*.d.ts",
    "dist/*.d.ts.map"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@sonde-sh/spec": "workspace:*",
    "execa": "^9.6.1"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.19.13",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
