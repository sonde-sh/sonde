{
  "name": "@sonde-sh/spec",
  "version": "0.1.0",
  "description": "Schema, types, and loaders for the Sonde manifest contract.",
  "type": "module",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sonde-sh/sonde.git"
  },
  "homepage": "https://github.com/sonde-sh/sonde#readme",
  "bugs": {
    "url": "https://github.com/sonde-sh/sonde/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/*.js",
    "dist/*.d.ts",
    "dist/*.d.ts.map"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "typescript": "5.9.2",
    "vitest": "^3.2.4"
  }
}
