{
  "name": "sonde",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sonde-sh/sonde.git"
  },
  "homepage": "https://github.com/sonde-sh/sonde#readme",
  "bugs": {
    "url": "https://github.com/sonde-sh/sonde/issues"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --ui tui",
    "lint": "turbo run lint --parallel --log-order grouped",
    "test": "turbo run test --parallel --log-order grouped",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types --parallel --log-order grouped",
    "changeset": "changeset",
    "changeset:status": "changeset status --verbose",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "prettier": "^3.8.1",
    "turbo": "^2.8.13",
    "typescript": "^5.9.3",
    "syncpack": "^14.0.1"
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22"
  }
}
