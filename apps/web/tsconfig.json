{
  "extends": "@repo/typescript-config/nextjs.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "strictNullChecks": true,
    "paths": {
      "fumadocs-mdx:collections/*": ["./.source/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.mdx",
    "next-env.d.ts",
    "next.config.js",
    "source.config.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
